# ── Frontend (Vite – these prefixes are exposed to the browser) ──────────────

# Supabase project URL (Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe to expose in browser)
SUPABASE_ANON_KEY=your-anon-key-here

# Backend API base URL (empty = use relative /api routes, good for Vercel full-stack)
# e.g. https://xps-admin.vercel.app  or  http://localhost:3000
API_URL=

# Base path for GitHub Pages (e.g. /XPS_ADMIN_CONTROL_PLANE/)
# Leave empty or / for Vercel / root deployments
BASE_PATH=/

# Dev auth bypass — set to 'false' to enforce Supabase auth (for production)
# Defaults to true (bypassed) so app boots directly without login
DEV_AUTH=true

# ── Backend / Vercel serverless (api/*.js) ────────────────────────────────────

# Supabase service-role key – NEVER expose to browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# LLM provider – set ONE of the following:
# Option A – OpenAI
OPENAI_API_KEY=sk-...

# Option B – Groq (free tier available)
# GROQ_API_KEY=gsk_...

# Option C – Gemini (Google)
# GEMINI_API_KEY=...

# Option D – Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434

# Browser automation worker (Playwright)
# BROWSER_WORKER_URL=http://localhost:3001
