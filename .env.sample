# ── Frontend (Vite – prefix VITE_ to expose to browser) ──────────────────────

# Supabase project URL (Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe to expose in browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API base URL (empty = use relative /api routes, good for Vercel full-stack)
# e.g. https://xps-admin.vercel.app  or  http://localhost:3000
VITE_API_URL=

# Base path for GitHub Pages (e.g. /XPS_ADMIN_CONTROL_PLANE/)
# Leave empty or / for Vercel / root deployments
VITE_BASE_PATH=/

# ── Backend / Vercel serverless (api/*.js) ────────────────────────────────────

# Supabase service-role key – NEVER expose to browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# LLM provider – set ONE of the following:
# Option A – OpenAI
OPENAI_API_KEY=sk-...

# Option B – Groq (free tier available)
# GROQ_API_KEY=gsk_...

# Option C – Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
